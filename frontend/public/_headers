# Cloudflare Pages: more-specific paths win over generic ones.
# Long-lived cache for Vite fingerprinted assets only.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker must always revalidate so updates are discoverable.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# App shell — avoid indefinite browser/CDN staleness for HTML.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate
