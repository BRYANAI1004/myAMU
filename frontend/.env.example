# Backend base URL (no trailing slash). Required for production when the frontend is not served
# from the same origin as the API (e.g. Vercel app + API on Render/Railway).
#
# Local (direct to local API — Vite dev proxy is disabled when this is set):
#   VITE_API_BASE_URL=http://127.0.0.1:3001
#
# Production / preview:
#   VITE_API_BASE_URL=https://your-api.example.com
#
# Omit or leave empty only when `/api` is same-origin or you rely on Vite’s dev proxy (no env).
VITE_API_BASE_URL=
