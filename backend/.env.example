DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=school

# Optional: restrict CORS when the browser frontend is on another origin (comma-separated).
# Example production: CORS_ORIGINS=https://your-app.vercel.app,https://your-preview.vercel.app
# Example local Vite: CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Omit both to keep previous behavior (reflect request Origin — convenient for local dev).
# CORS_ORIGINS=
# CORS_ORIGIN=

# Create portal billing tables + dev seed (AMU123456): npm run db:bootstrap-portal

# Legacy Mongo seed only (`npm run seed` under backend/legacy)
# MONGODB_URI=mongodb://127.0.0.1:27017/student-tuition-portal
